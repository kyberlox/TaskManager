# PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=taskmanager

# App
DATABASE_URL=postgresql://postgres:postgres@db:5432/taskmanager
DOMAIN=localhost
SECRET_KEY=your-secret-key-change-in-production

# Uploads
UPLOAD_FOLDER=./uploads
MAX_CONTENT_LENGTH=16777216  # 16 MB

# GigaChat API
GIGACHAT_CLIENT_ID=your-client-id
# Scope определяет доступные возможности API. Возможные значения:
# GIGACHAT_API_PERS — персональный доступ (чат, суммаризация, генерация изображений)
# GIGACHAT_API_CORP — корпоративный доступ
# Для генерации изображений используйте GIGACHAT_API_PERS (поддерживается для моделей GigaChat-2-Lite и выше)
GIGACHAT_SCOPE=GIGACHAT_API_PERS
GIGACHAT_AUTHORIZATION_KEY=your-authorization-key
#GIGACHAT_API_URL=https://gigachat.devices.sberbank.ru/api/v1
GIGACHAT_MODEL=GigaChat-2-Lite
